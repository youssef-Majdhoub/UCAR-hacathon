<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title><%= title %></title>
    
    <link rel="icon" type="image/png" href="/images/logo-ucar.png">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

    <header>
    <a href="/" class="logo">
        <img src="/images/logo-ucar.png" alt="Logo UCAR">
    </a>
    
    <nav class="nav-links">
        <a href="#" class="nav-item">Accueil</a>
        <a href="#" class="nav-item">À propos</a>
        <a href="#" class="nav-item">Programmes Académiques</a>
        
        <div class="dropdown">
            <a href="#" class="dropbtn">Institution</a>
            <div class="dropdown-content">
                <a href="/institution_academic_intermediate" class="nav-item">ACADÉMIQUES</a>
                <a href="/institution_student_life_intermediate" class="nav-item">VIE ÉTUDIANTE</a>
                <a href="/institution_finance_intermediate" class="nav-item">FINANCES</a>
                <a href="/institution_hr_intermediate" class="nav-item">RESSOURCES HUMAINES</a>
                <a href="/institution_esg_intermediate" class="nav-item">ESG / RSE</a>
                <a href="/institution_infrastructure_intermediate" class="nav-item">INFRASTRUCTURE</a>
                <a href="/institution_research_intermediate" class="nav-item">RECHERCHE</a>
                <a href="/institution_partnerships_intermediate" class="nav-item">PARTENARIATS MONDIAUX</a>
                <a href="/institution_employment_intermediate" class="nav-item">INSERTION PRO</a>
            </div>
        </div>
        
        <div class="dropdown">
            <a href="#" class="dropbtn">Université de l'UCAR</a>
            <div class="dropdown-content">
                 <a href="/database-management" class="nav-item">GESTION DE BASE DE DONNÉES</a>
                 <a href="/kpi_menu_intermediate" class="nav-item">MENU DES KPI</a>
</div>
        </div>
        
        <div class="dropdown">
            <a href="#" class="dropbtn">Vie Étudiante</a>
            <div class="dropdown-content">
                <a href="#" class="nav-item">Inscription</a>
                <a href="#" class="nav-item">Clubs</a>
                <a href="#" class="nav-item">Stages</a>
            </div>
        </div>

        <a href="#" class="nav-item">Excellence en Recherche</a>
        <a href="#" class="nav-item">Partenariats Mondiaux</a>
        <a href="#" class="nav-item">Actualités</a>
    </nav>

    <div class="right-nav">
        <a href="#" class="log-in">Se connecter</a>
    </div>
</header>

    <section class="hero">
        <div class="hero-left">
            <h1 class="hero-title">admissions <%= year %></h1>
            
            <div class="hero-meta">
                <span class="badge">📅 Ouvert Maintenant</span>
                <span class="badge">📍 Campus Principal et en ligne</span>
            </div>

            <h2 class="hero-subtitle">Libérez votre potentiel académique à grande échelle</h2>
            <p class="hero-desc">
                Rejoignez notre communauté mondiale d'étudiants, de chercheurs avant-gardistes et les programmes innovants qui les animent.
            </p>

            <div class="hero-actions">
                <a href="#" class="btn-primary">Postuler maintenant</a>
                <a href="#" class="btn-secondary">Voir l'agenda académique &rarr;</a>
            </div>
        </div>

        <div class="hero-right">
            <img src="/images/campus-showcase.jpg" alt="Campus UCAR" class="hero-image">
            <div class="image-caption">APERÇU DE LA VIE SUR LE CAMPUS</div>
        </div>
    </section>

    <section class="bottom-section">
        <h2 class="bottom-title">Libérez votre super-équipe académique</h2>
    </section>

</body>
</html>