<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

    <header>
        <a href="/" class="logo">
        <img src="/images/logo-ucar.png" alt="UCAR Logo">
    </a>
        
        <nav class="nav-links">
            <a href="#">Institution</a>
            <a href="#">University of UCAR</a>
            <a href="#">Student Life</a>
        </nav>

        <div class="right-nav">
            <span class="search-icon">🔍</span>
            <a href="#" class="log-in">Sign in</a>
        </div>
    </header>

    <section class="hero">
        <div class="hero-left">
            <h1 class="hero-title">admissions'<%= year %></h1>
            
            <div class="hero-meta">
                <span class="badge">📅 Open Now</span>
                <span class="badge">📍 Main Campus and online</span>
            </div>

            <h2 class="hero-subtitle">Unlock your academic potential at scale</h2>
            <p class="hero-desc">
                Join our global community of forward-thinking students, researchers, and the innovative programs that fuel them.
            </p>

            <div class="hero-actions">
                <a href="#" class="btn-primary">Apply now</a>
                <a href="#" class="btn-secondary">See academic agenda &rarr;</a>
            </div>
        </div>

        <div class="hero-right">
            <div class="glass-card">
                <h3>Campus Life Showcase</h3>
                <p>Image Placeholder</p>
            </div>
        </div>
    </section>

    <section class="bottom-section">
        <h2 class="bottom-title">Unleash your academic superteam</h2>
    </section>

</body>
</html>