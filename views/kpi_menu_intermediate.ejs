<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tableau de Bord KPI - UCAR</title>
    <link rel="icon" type="image/png" href="/images/logo-ucar.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

    <header>
        <a href="/" class="logo">
            <img src="/images/logo-ucar.png" alt="Logo Université de Carthage">
        </a>
        <nav class="nav-links">
            <a href="/" class="nav-item">ACCUEIL</a>
            <a href="/about" class="nav-item">À PROPOS</a>
            <a href="/programmes" class="nav-item">PROGRAMMES ACADÉMIQUES</a>
            <div class="dropdown">
                <a href="#" class="dropbtn">INSTITUTION <span class="arrow">⌄</span></a>
                <div class="dropdown-content">
                    <a href="/institution_academic_intermediate">ACADÉMIQUES</a>
                    <a href="/institution_student_life_intermediate">VIE ÉTUDIANTE</a>
                    <a href="/institution_finance_intermediate">FINANCES</a>
                    <a href="/institution_hr_intermediate">RESSOURCES HUMAINES</a>
                    <a href="/institution_esg_intermediate">ESG / RSE</a>
                    <a href="/institution_infrastructure_intermediate">INFRASTRUCTURE</a>
                    <a href="/institution_research_intermediate">RECHERCHE</a>
                    <a href="/institution_partnerships_intermediate">PARTENARIATS</a>
                    <a href="/institution_employment_intermediate">INSERTION PRO</a>
                </div>
            </div>
            <a href="/news" class="nav-item">ACTUALITÉS</a>
        </nav>
        <div class="right-nav">
            <a href="/login" class="log-in">SE CONNECTER</a>
        </div>
    </header>

    <div class="intermediate-container">
        <h2 class="page-title">Tableau de Bord des KPI</h2>
        
        <div class="action-cards" style="margin-top: 40px;">
            
            <a href="/kpi-academic" class="action-card">
                <div class="card-icon">🎓</div>
                <h3>Académique</h3>
                <p>Taux de réussite, d'assiduité et progression pédagogique.</p>
            </a>

            <a href="/kpi-employment" class="action-card">
                <div class="card-icon">💼</div>
                <h3>Insertion Pro</h3>
                <p>Employabilité et délais d'accès au premier emploi.</p>
            </a>

            <a href="/kpi-finance" class="action-card">
                <div class="card-icon">💰</div>
                <h3>Finances</h3>
                <p>Exécution budgétaire, coût par étudiant et dépenses.</p>
            </a>

            <a href="/kpi-esg" class="action-card">
                <div class="card-icon">🌱</div>
                <h3>ESG / RSE</h3>
                <p>Consommation d'énergie, empreinte carbone et recyclage.</p>
            </a>

            <a href="/kpi-hr" class="action-card">
                <div class="card-icon">👥</div>
                <h3>RH</h3>
                <p>Absentéisme, charge d'enseignement et stabilité des équipes.</p>
            </a>

            <a href="/kpi-research" class="action-card">
                <div class="card-icon">🔬</div>
                <h3>Recherche</h3>
                <p>Publications, brevets déposés et financements obtenus.</p>
            </a>

            <a href="/kpi-infrastructure" class="action-card">
                <div class="card-icon">🏗️</div>
                <h3>Infrastructure</h3>
                <p>Occupation des salles, état IT et travaux en cours.</p>
            </a>

            <a href="/kpi-partnerships" class="action-card">
                <div class="card-icon">🌍</div>
                <h3>Partenariats</h3>
                <p>Mobilité étudiante et réseaux académiques actifs.</p>
            </a>

        </div>
    </div>

</body>
</html>